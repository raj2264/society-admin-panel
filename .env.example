# ============================================
# SUPABASE CREDENTIALS
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# SITE CONFIGURATION
# ============================================
# Required for authentication redirects and email links
# Staging: https://admin-staging.yourdomain.com
# Production: https://admin.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://your-admin-domain.com

# ============================================
# EMAIL SERVICE (Resend)
# ============================================
# For sending bill emails, payment receipts, etc.
# Get key from: https://resend.com/api-keys
# Leave blank to disable email features
RESEND_API_KEY=re_your-resend-api-key-here

# ============================================
# ENVIRONMENT
# ============================================
# Automatically set by Vercel, but can override
NODE_ENV=production
